FROM python:3.12-slim

RUN apt-get update && apt-get install -y \
    gcc \
    g++ \
    make \
    curl \
    cmake \
    git \
    pkg-config \
    && rm -rf /var/lib/apt/lists/*

COPY --from=ghcr.io/astral-sh/uv:latest /uv /bin/uv

WORKDIR /app

COPY pyproject.toml uv.lock ./

# Clear cache and install with verbose output (but capture it)
RUN uv cache clean && \
    uv pip install --verbose "h3>=4.0.0" 2>&1 | head -100

RUN uv sync --frozen --no-dev --verbose 2>&1 | head -100

COPY . .

RUN uv pip install -e .

ENTRYPOINT ["uv", "run", "water-timeseries"]